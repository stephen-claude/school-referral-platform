rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function isRole(role) {
      return isSignedIn() && getUserData().role == role;
    }
    
    function isTeacher() {
      return isRole('teacher');
    }
    
    function isSchoolAdmin() {
      return isRole('school_admin');
    }
    
    function isClinicAdmin() {
      return isRole('clinic_admin');
    }
    
    function belongsToSameSchool(schoolId) {
      return isSignedIn() && getUserData().schoolId == schoolId;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    // Users collection - user profiles
    match /users/{userId} {
      // Allow users to read their own profile, or clinic admins to read any profile
      allow read: if request.auth != null && (request.auth.uid == resource.data.uid || isClinicAdmin());
      
      // Allow authenticated users to create their own profile on first sign-in,
      // or clinic admins to create users with specific roles (via admin panel)
      allow create: if request.auth != null && (request.auth.uid == request.resource.data.uid || isClinicAdmin());
      
      // Allow users to update their own profile, or clinic admins to update any user
      allow update: if request.auth != null && (request.auth.uid == resource.data.uid || isClinicAdmin());
      
      // Only clinic admins can delete user profiles
      allow delete: if isClinicAdmin();
    }
    
    // Schools collection
    match /schools/{schoolId} {
      allow read: if isSignedIn();
      // Allow any authenticated user to create schools for now
      // TODO: Restrict to clinic admins only after initial setup
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (isClinicAdmin() || (isSchoolAdmin() && belongsToSameSchool(schoolId)));
      allow delete: if isClinicAdmin();
    }
    
    // Students collection
    match /students/{studentId} {
      allow read: if isSignedIn();
      // Allow any authenticated user to create students for now
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSchoolAdmin() || isClinicAdmin();
    }
    
    // Referrals collection
    match /referrals/{referralId} {
      allow read: if isSignedIn();
      // Allow any authenticated user to create referrals for now
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isClinicAdmin();
    }
    
    // Questionnaires collection
    match /questionnaires/{questionnaireId} {
      allow read: if isSignedIn();
      // Allow any authenticated user to create questionnaires for now
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isClinicAdmin();
    }
    
    // Notes collection (internal clinic notes)
    match /notes/{noteId} {
      allow read: if isSignedIn();
      // Allow any authenticated user to create notes for now
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isClinicAdmin();
    }
    
    // Activities/Audit log collection
    match /activities/{activityId} {
      allow read: if isClinicAdmin();
      allow create: if isSignedIn();
      allow update: if false; // Activities are immutable
      allow delete: if isClinicAdmin();
    }
  }
}
